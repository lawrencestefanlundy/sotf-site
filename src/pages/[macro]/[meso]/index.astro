---
import Base from "../../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { macroBySlug, mesoBySlug } from "../../../data/taxonomy";

export async function getStaticPaths() {
  const concepts = await getCollection("concepts");
  const pairs = new Set<string>();
  for (const c of concepts) {
    const [macro, meso] = c.id.split("/");
    if (macro && meso) pairs.add(`${macro}/${meso}`);
  }
  return [...pairs].map((p) => {
    const [macro, meso] = p.split("/");
    return { params: { macro, meso } };
  });
}

const { macro, meso } = Astro.params;
const concepts = await getCollection("concepts");
const inMeso = concepts.filter((c) => c.id.startsWith(`${macro}/${meso}/`));

const macroEntry = macroBySlug(macro as string);
const mesoEntry = mesoBySlug(macro as string, meso as string);
const macroName = macroEntry?.name ?? macro;
const mesoName = mesoEntry?.name ?? (meso as string).replace(/-/g, " ");
const mesoBlurb = mesoEntry?.blurb;

const sorted = [...inMeso].sort((a, b) =>
  a.data.canonical_name.localeCompare(b.data.canonical_name)
);
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={`${mesoName} · ${macroName}`}>
  <div class="breadcrumb">
    <a href={`${BASE}/`}>Now</a> &nbsp;/&nbsp; <a href={`${BASE}/${macro}/`}>{macroName}</a> &nbsp;/&nbsp; {mesoName}
  </div>
  <section class="hero">
    <h1>{mesoName}</h1>
    {mesoBlurb && <p>{mesoBlurb}</p>}
    <div class="meta" style="margin-top: 0.8rem;">{inMeso.length} concept{inMeso.length === 1 ? "" : "s"} in this cluster</div>
  </section>

  <section>
    <div class="grid-3">
      {sorted.map((c) => (
        <a href={`${BASE}/${c.id}/`} class="card">
          <h2>{c.data.canonical_name}</h2>
          {c.data.sources_30d > 0 && (
            <div class="meta">+{c.data.sources_30d} sources in 30d</div>
          )}
          {(!c.data.sources_30d && c.data.frontier && c.data.frontier.length > 0) && (
            <div class="meta">{c.data.frontier.length} frontier question{c.data.frontier.length > 1 ? "s" : ""}</div>
          )}
        </a>
      ))}
    </div>
  </section>
</Base>
