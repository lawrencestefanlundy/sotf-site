---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { MACROS } from "../data/taxonomy";

const concepts = await getCollection("concepts");

function countForMacro(slug: string): number {
  return concepts.filter((c) => c.id.startsWith(`${slug}/`)).length;
}
---

<Base title="Now" description="Lawrence Lundy-Bryan — deep-tech reference">
  <section class="hero">
    <h1>State of the Future</h1>
    <p>A public reference layer for the technology graph Lawrence Lundy-Bryan tracks. {concepts.length} concepts across nine macro domains — compute, sensing, energy, materials, photonic systems, and the frontier where they meet. Updated nightly from the underlying knowledge base.</p>
  </section>

  <section>
    <div class="grid-3">
      {MACROS.map((m) => (
        <a href={`/${m.slug}/`} class="card">
          <h2>{m.name}</h2>
          <div class="meta">{countForMacro(m.slug)} concepts</div>
          <p>{m.blurb}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
