---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { macroBySlug, mesosForMacro } from "../../data/taxonomy";

export async function getStaticPaths() {
  const concepts = await getCollection("concepts");
  const macros = new Set(concepts.map((c) => c.id.split("/")[0]));
  return [...macros].map((m) => ({ params: { macro: m } }));
}

const { macro } = Astro.params;
const concepts = await getCollection("concepts");
const inMacro = concepts.filter((c) => c.id.startsWith(`${macro}/`));

// Distinct meso slugs present in the corpus (defensive — should match taxonomy.ts)
const presentMesoSlugs = new Set(inMacro.map((c) => c.id.split("/")[1]));

const macroEntry = macroBySlug(macro as string);
const macroName = macroEntry?.name ?? macro;
const macroBlurb = macroEntry?.blurb;

// Mesos for this macro, with concept counts
const mesos = mesosForMacro(macro as string)
  .filter((m) => presentMesoSlugs.has(m.slug))
  .map((m) => ({
    ...m,
    count: inMacro.filter((c) => c.id.startsWith(`${macro}/${m.slug}/`)).length,
  }));
---

<Base title={macroName}>
  <div class="breadcrumb"><a href="/">Now</a> &nbsp;/&nbsp; {macroName}</div>
  <section class="hero">
    <h1>{macroName}</h1>
    {macroBlurb && <p>{macroBlurb}</p>}
    <div class="meta" style="margin-top: 0.8rem;">{inMacro.length} concepts across {mesos.length} clusters</div>
  </section>

  <section>
    <div class="grid-3">
      {mesos.map((m) => (
        <a href={`/${macro}/${m.slug}/`} class="card">
          <h2>{m.name}</h2>
          <div class="meta">{m.count} concept{m.count === 1 ? "" : "s"}</div>
          <p>{m.blurb}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
